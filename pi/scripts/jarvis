#!/bin/bash
# jarvis — Project 300K Pi assistant
# Usage: jarvis <command>

DB="/mnt/usb/data/obd.db"
LOG="/mnt/usb/logs/obd.log"
REPO="/home/balu/project300k"
PI_DIR="$REPO/pi"
PIP="$PI_DIR/venv/bin/pip"

BOLD="\033[1m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
RESET="\033[0m"

_header() { echo -e "\n${BOLD}$1${RESET}"; }
_ok()     { echo -e "${GREEN}✓ $1${RESET}"; }
_warn()   { echo -e "${YELLOW}! $1${RESET}"; }
_err()    { echo -e "${RED}✗ $1${RESET}"; }

_require_db() {
    if [ ! -f "$DB" ]; then
        _err "Database not found at $DB — is the USB drive mounted?"
        exit 1
    fi
}

_require_log() {
    if [ ! -f "$LOG" ]; then
        _err "Log not found at $LOG — is the USB drive mounted? Try: jarvis journal"
        exit 1
    fi
}

cmd="${1:-help}"

case "$cmd" in

    # ── Logs ────────────────────────────────────────────────────────────────

    logs)
        _require_log
        echo -e "${BOLD}Tailing $LOG — Ctrl+C to exit${RESET}"
        tail -f "$LOG"
        ;;

    last)
        _require_log
        n="${2:-50}"
        tail -n "$n" "$LOG"
        ;;

    journal)
        # Collector logs via systemd — works even if USB is not mounted
        journalctl -u obd-collector.service -n "${2:-50}" --no-pager
        ;;

    sync-log)
        journalctl -u obd-sync.service -n "${2:-50}" --no-pager
        ;;

    # ── Services ─────────────────────────────────────────────────────────────

    status)
        _header "rfcomm-connect"
        sudo systemctl status rfcomm-connect.service --no-pager -l
        _header "obd-collector"
        sudo systemctl status obd-collector.service --no-pager -l
        _header "obd-sync"
        sudo systemctl status obd-sync.service --no-pager -l
        _header "obd-led"
        sudo systemctl status obd-led.service --no-pager -l
        ;;

    restart)
        echo "Restarting obd-collector..."
        sudo systemctl restart obd-collector.service
        sleep 2
        sudo systemctl status obd-collector.service --no-pager -l
        ;;

    stop)
        sudo systemctl stop obd-collector.service
        _ok "obd-collector stopped"
        ;;

    start)
        sudo systemctl start obd-collector.service
        sleep 2
        sudo systemctl status obd-collector.service --no-pager -l
        ;;

    sync)
        echo "Triggering sync..."
        sudo systemctl start obd-sync.service
        sleep 3
        _header "Sync result"
        journalctl -u obd-sync.service -n 30 --no-pager
        ;;

    # ── Database ─────────────────────────────────────────────────────────────

    db)
        _require_db
        echo -e "${BOLD}SQLite shell — $DB${RESET}"
        echo ".headers on
.mode column" | cat - | sqlite3 "$DB"
        ;;

    rows)
        _require_db
        _header "Row counts"
        sqlite3 -column -header "$DB" "
            SELECT table_name,
                   total,
                   unsynced,
                   CASE WHEN total > 0
                        THEN ROUND(unsynced * 100.0 / total, 1) || '%'
                        ELSE '0%'
                   END AS unsynced_pct
            FROM (
                SELECT 'obd_1s'         AS table_name, COUNT(*) AS total, SUM(synced=0) AS unsynced FROM obd_1s
                UNION ALL
                SELECT 'obd_5s',         COUNT(*), SUM(synced=0) FROM obd_5s
                UNION ALL
                SELECT 'obd_30s',        COUNT(*), SUM(synced=0) FROM obd_30s
                UNION ALL
                SELECT 'ford_obd_5s',    COUNT(*), SUM(synced=0) FROM ford_obd_5s
                UNION ALL
                SELECT 'ford_obd_10s',   COUNT(*), SUM(synced=0) FROM ford_obd_10s
                UNION ALL
                SELECT 'ford_obd_20s',   COUNT(*), SUM(synced=0) FROM ford_obd_20s
                UNION ALL
                SELECT 'trips',          COUNT(*), SUM(synced=0) FROM trips
                UNION ALL
                SELECT 'dtc_events',     COUNT(*), SUM(synced=0) FROM dtc_events
                UNION ALL
                SELECT 'pi_health_log',  COUNT(*), SUM(synced=0) FROM pi_health_log
            );
        "
        ;;

    trips)
        _require_db
        n="${2:-10}"
        _header "Last $n trips"
        sqlite3 -column -header "$DB" "
            SELECT
                trip_number AS '#',
                SUBSTR(start_time, 1, 16) AS started,
                CASE
                    WHEN end_time IS NULL THEN 'ACTIVE'
                    ELSE SUBSTR(end_time, 1, 16)
                END AS ended,
                CASE
                    WHEN duration_s IS NULL AND end_time IS NULL THEN 'ongoing'
                    WHEN duration_s IS NULL THEN '?'
                    WHEN duration_s < 60 THEN duration_s || 's'
                    ELSE (duration_s / 60) || 'm ' || (duration_s % 60) || 's'
                END AS duration
            FROM trips
            ORDER BY start_time DESC
            LIMIT $n;
        "
        ;;

    dtc)
        _require_db
        _header "DTC events"
        result=$(sqlite3 -column -header "$DB" "
            SELECT
                SUBSTR(timestamp, 1, 16) AS time,
                code,
                description,
                status,
                scan_trigger AS trigger
            FROM dtc_events
            ORDER BY timestamp DESC
            LIMIT 20;
        ")
        if [ -z "$result" ]; then
            _ok "No DTC events recorded"
        else
            echo "$result"
        fi
        ;;

    ford)
        _require_db
        # Each Ford tier has its own cadence (5s/10s/20s) and the rows do not
        # line up, so each is shown as its own latest-N table rather than joined.
        _header "TCM — transmission (ford_obd_5s)"
        sqlite3 -column -header "$DB" "
            SELECT
                SUBSTR(timestamp, 12, 8)        AS time,
                trans_temp_c                    AS sump_c,
                trans_oil_temp2_c               AS cooler_c,
                trans_line_pressure_kpa         AS line_kpa,
                trans_gear                      AS gear,
                ROUND(tcc_ratio, 2)             AS tcc
            FROM ford_obd_5s
            ORDER BY timestamp DESC
            LIMIT ${2:-10};
        "
        _header "PCM — boost / knock / VCT (ford_obd_10s)"
        sqlite3 -column -header "$DB" "
            SELECT
                SUBSTR(timestamp, 12, 8)        AS time,
                oil_pressure_kpa                AS oil_kpa,
                ROUND(knock_retard_deg, 2)      AS knock,
                ROUND(boost_desired_psi, 2)     AS boost_des,
                ROUND(boost_actual_psi, 2)      AS boost_act,
                cac_temp_c                      AS cac_c,
                ROUND(wastegate_pct, 1)         AS wg_pct,
                ROUND(vct_intake_deg, 2)        AS vct_in,
                ROUND(vct_exhaust_deg, 2)       AS vct_ex
            FROM ford_obd_10s
            ORDER BY timestamp DESC
            LIMIT ${2:-10};
        "
        _header "Misfire accumulators (ford_obd_20s)"
        sqlite3 -column -header "$DB" "
            SELECT
                SUBSTR(timestamp, 12, 8) AS time,
                misfire_acc_cyl1         AS cyl1,
                misfire_acc_cyl2         AS cyl2,
                misfire_acc_cyl3         AS cyl3,
                misfire_acc_cyl4         AS cyl4
            FROM ford_obd_20s
            ORDER BY timestamp DESC
            LIMIT ${2:-5};
        "
        ;;

    validate)
        _require_db
        # One-shot sanity pass over the data pipeline. Surfaces "collector alive
        # but not writing" and "sync stuck" without manual SQL.

        _header "Integrity (quick_check)"
        integrity=$(sqlite3 "$DB" "PRAGMA quick_check;" 2>&1)
        if [ "$integrity" = "ok" ]; then
            _ok "ok"
        else
            _err "$integrity"
        fi

        _header "WAL size"
        if [ -f "$DB-wal" ]; then
            wal_bytes=$(stat -c%s "$DB-wal" 2>/dev/null || echo 0)
            awk "BEGIN{printf \"  %.1f MB\n\", $wal_bytes/1048576}"
            # SQLite auto-checkpoints around 4MB; a much larger WAL means a
            # long-lived reader (datasette? stuck sync?) is pinning it.
            if [ "$wal_bytes" -gt 67108864 ]; then
                _warn "WAL > 64MB — a long-lived reader may be blocking checkpoint"
            fi
        else
            _ok "no WAL file (fully checkpointed)"
        fi

        _header "Newest row per table"
        sqlite3 -column "$DB" "
            SELECT 'obd_1s'       AS tbl, MAX(timestamp) AS newest FROM obd_1s
            UNION ALL SELECT 'obd_5s',       MAX(timestamp) FROM obd_5s
            UNION ALL SELECT 'obd_30s',      MAX(timestamp) FROM obd_30s
            UNION ALL SELECT 'ford_obd_5s',  MAX(timestamp) FROM ford_obd_5s
            UNION ALL SELECT 'ford_obd_10s', MAX(timestamp) FROM ford_obd_10s
            UNION ALL SELECT 'ford_obd_20s', MAX(timestamp) FROM ford_obd_20s;
        " | sed 's/^/  /'

        _header "Open trips (end_time IS NULL)"
        open_trips=$(sqlite3 "$DB" "SELECT COUNT(*) FROM trips WHERE end_time IS NULL;")
        if [ "$open_trips" -eq 0 ]; then
            _ok "none"
        elif [ "$open_trips" -eq 1 ]; then
            _warn "1 open trip — normal only if a trip is active right now"
        else
            _err "$open_trips open trips — boot repair should leave at most 1"
        fi

        _header "Unsynced backlog (OBD tables)"
        sqlite3 -column -header "$DB" "
            SELECT COUNT(*) AS rows, MIN(timestamp) AS oldest FROM (
                SELECT timestamp FROM obd_1s       WHERE synced=0
                UNION ALL SELECT timestamp FROM obd_5s       WHERE synced=0
                UNION ALL SELECT timestamp FROM obd_30s      WHERE synced=0
                UNION ALL SELECT timestamp FROM ford_obd_5s  WHERE synced=0
                UNION ALL SELECT timestamp FROM ford_obd_10s WHERE synced=0
                UNION ALL SELECT timestamp FROM ford_obd_20s WHERE synced=0
            );
        " | sed 's/^/  /'
        ;;

    # ── System health ────────────────────────────────────────────────────────

    health)
        _header "CPU Temperature"
        if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
            awk '{printf "  %.1f°C\n", $1/1000}' /sys/class/thermal/thermal_zone0/temp
        else
            _warn "CPU temp unavailable"
        fi

        _header "Memory"
        free -h | awk 'NR==1{print "  "$0} NR==2{print "  "$0}'

        _header "USB Drive"
        if mountpoint -q /mnt/usb; then
            df -h /mnt/usb | awk 'NR==2{printf "  %s used of %s (%s free)\n", $3, $2, $4}'
            _ok "Mounted at /mnt/usb"
        else
            _err "USB drive not mounted"
        fi

        _header "Uptime"
        uptime | sed 's/^ */  /'

        _header "Restart counter"
        if [ -f /mnt/usb/data/restart_count ]; then
            echo "  $(cat /mnt/usb/data/restart_count) restarts since last install"
        else
            _warn "restart_count not found"
        fi
        ;;

    net)
        # Hotspot/wlan0 control. After a drive's one sync, obd-sync.service drops
        # wlan0 (suppressing autoconnect until reboot) — UNLESS the hold flag
        # /run/obd-keep-online is set. To debug remotely: SSH in during the
        # post-sync grace window, then `jarvis net hold` to stay online; `jarvis
        # net release` when done (or just reboot — the flag is on tmpfs).
        HOLD_FLAG=/run/obd-keep-online
        case "${2:-status}" in
            hold)
                sudo touch "$HOLD_FLAG"
                sudo nmcli device connect wlan0 >/dev/null 2>&1 || true
                _ok "Hold ON — link will NOT be auto-disconnected (clears on reboot or 'jarvis net release')"
                ;;
            release)
                sudo rm -f "$HOLD_FLAG"
                _ok "Hold OFF — normal once-per-drive disconnect resumes"
                ;;
            up)
                sudo nmcli device connect wlan0
                _ok "wlan0 connect requested (autoconnect re-enabled until reboot)"
                ;;
            down)
                sudo nmcli device disconnect wlan0
                _ok "wlan0 disconnected (autoconnect suppressed until reboot)"
                ;;
            status)
                if [ -f "$HOLD_FLAG" ]; then _ok "Hold is ON (auto-disconnect disabled)"; else echo "Hold is off"; fi
                nmcli device status
                ;;
            *)
                _err "Unknown net subcommand: $2"
                echo "Usage: jarvis net [hold|release|up|down|status]"
                exit 1
                ;;
        esac
        ;;

    bt)
        _header "Bluetooth dongle"
        hciconfig 2>/dev/null || _err "hciconfig failed — dongle missing?"

        _header "RFCOMM connections"
        rfcomm 2>/dev/null || _warn "No RFCOMM connections"

        _header "rfcomm-connect service"
        sudo systemctl status rfcomm-connect.service --no-pager -l
        ;;

    # ── Datasette ────────────────────────────────────────────────────────────

    datasette)
        case "${2:-status}" in
            start)
                sudo systemctl start obd-datasette.service
                sleep 1
                sudo systemctl status obd-datasette.service --no-pager -l
                ;;
            stop)
                sudo systemctl stop obd-datasette.service
                _ok "Datasette stopped"
                ;;
            status)
                sudo systemctl status obd-datasette.service --no-pager -l
                ;;
            *)
                _err "Unknown datasette subcommand: $2"
                echo "Usage: jarvis datasette [start|stop|status]"
                exit 1
                ;;
        esac
        ;;

    # ── Status LEDs ──────────────────────────────────────────────────────────

    led)
        case "${2:-status}" in
            status)
                sudo systemctl status obd-led.service --no-pager -l
                ;;
            test)
                # Stop the daemon first so it releases the GPIO pins, run the
                # colour cycle in the foreground, then hand the pins back.
                echo "Cycling both LEDs (~8s) — watch the wiring..."
                sudo systemctl stop obd-led.service
                "$PI_DIR/venv/bin/python" "$PI_DIR/src/led_status.py" --test
                sudo systemctl start obd-led.service
                _ok "Test complete — daemon restarted"
                ;;
            start|stop|restart)
                sudo systemctl "$2" obd-led.service
                _ok "obd-led $2"
                ;;
            *)
                _err "Unknown led subcommand: $2"
                echo "Usage: jarvis led [status|test|start|stop|restart]"
                exit 1
                ;;
        esac
        ;;

    # ── Maintenance ───────────────────────────────────────────────────────────

    update)
        _header "Pulling latest code"
        cd "$REPO" && git pull
        chmod +x "$PI_DIR/scripts/jarvis"

        _header "Restarting collector"
        sudo systemctl restart obd-collector.service
        sleep 2
        sudo systemctl status obd-collector.service --no-pager -l
        ;;

    # ── Help ─────────────────────────────────────────────────────────────────

    help|--help|-h)
        echo -e "${BOLD}Jarvis — Project 300K${RESET}"
        echo ""
        echo -e "${BOLD}Logs${RESET}"
        echo "  jarvis logs              Tail live OBD log (Ctrl+C to stop)"
        echo "  jarvis last [n]          Last n lines of log (default 50)"
        echo "  jarvis journal [n]       Collector logs via journald"
        echo "  jarvis sync-log [n]      Sync service logs via journald"
        echo ""
        echo -e "${BOLD}Services${RESET}"
        echo "  jarvis status            Status of all services"
        echo "  jarvis restart           Restart obd-collector"
        echo "  jarvis start             Start obd-collector"
        echo "  jarvis stop              Stop obd-collector"
        echo "  jarvis sync              Trigger sync now + show result"
        echo ""
        echo -e "${BOLD}Database${RESET}"
        echo "  jarvis db                Open SQLite shell"
        echo "  jarvis rows              Row counts + unsynced per table"
        echo "  jarvis trips [n]         Last n trips (default 10)"
        echo "  jarvis dtc               Recent DTC fault codes"
        echo "  jarvis ford [n]          Latest Ford Mode 22 readings (default 10)"
        echo "  jarvis validate          One-shot pipeline health check"
        echo ""
        echo -e "${BOLD}Datasette${RESET}"
        echo "  jarvis datasette         Status of Datasette service"
        echo "  jarvis datasette start   Start Datasette (localhost:8001 — SSH-tunnel to browse)"
        echo "  jarvis datasette stop    Stop Datasette"
        echo ""
        echo -e "${BOLD}Status LEDs${RESET}"
        echo "  jarvis led               obd-led service status"
        echo "  jarvis led test          Cycle both LEDs to verify wiring"
        echo "  jarvis led start|stop|restart   Control the LED daemon"
        echo ""
        echo -e "${BOLD}System${RESET}"
        echo "  jarvis health            CPU temp, memory, disk, uptime"
        echo "  jarvis bt                Bluetooth and RFCOMM status"
        echo "  jarvis net hold          Keep wlan0 up for debugging (disables post-sync disconnect)"
        echo "  jarvis net release       Resume normal once-per-drive disconnect"
        echo "  jarvis net [up|down|status]  Manually open/close/show the hotspot link"
        echo "  jarvis update            git pull + restart collector"
        ;;

    *)
        _err "Unknown command: $1"
        echo "Run 'jarvis help' to see available commands."
        exit 1
        ;;
esac
