# Project 300K — Backend (home server) configuration.
# Copy to .env for local dev:  cp .env.example .env
# .env is gitignored — never commit real values.
#
# This single .env serves both run modes:
#   • `make run`        — native dev; uses DATABASE_URL + API_KEY + LISTEN_ADDR
#   • `docker compose`  — uses DB_PASSWORD + API_KEY + BIND_ADDR (compose builds
#                         DATABASE_URL itself, pointing the api container at `db`)

# --- shared ----------------------------------------------------------------
# Bearer token the Pi presents on every /sync request.
# MUST match API_KEY in the Pi's /etc/obd-collector/config.env.
# Generate with: openssl rand -hex 32
API_KEY=REPLACE_ME_MATCH_THE_PI_API_KEY

# --- native dev (`make run`) -----------------------------------------------
# pgx URL against a local Postgres (Homebrew). Ignored by docker compose.
DATABASE_URL=postgres://localhost:5432/project300k_dev?sslmode=disable
LISTEN_ADDR=127.0.0.1:8080

# --- docker compose --------------------------------------------------------
# Password for the Postgres container's `app` user. Generate with: openssl rand -hex 16
DB_PASSWORD=change-me-local-dev
# Host interface the locally PUBLISHED :8080 binds to (dev convenience on the
# laptop). 127.0.0.1 keeps it off the laptop's LAN. Tailnet access to the api
# does NOT depend on this — it comes via the Tailscale sidecar.
BIND_ADDR=127.0.0.1

# --- tailscale sidecar (private mesh; the Pi reaches the laptop over this) ---
# Auth key from the Tailscale admin console → Settings → Keys (reusable,
# non-ephemeral). The laptop's Tailscale container uses it to join your tailnet.
TS_AUTHKEY=tskey-auth-REPLACE_ME
# Tailnet hostname for this laptop node (also its MagicDNS name).
TS_HOSTNAME=project300k-server

# --- grafana ---------------------------------------------------------------
# Admin password for the Grafana UI (user: admin), served on :3000 over the
# tailnet. Generate with: openssl rand -hex 16
GF_ADMIN_PASSWORD=change-me-local-dev

# --- frontend (Part 3 web app, :8090 on the tailnet) -----------------------
# Optional shared password (user "owner") on top of the tailnet; empty = no auth.
WEB_PASSWORD=
# Show a "DEMO DATA" banner — set true only on a public showcase instance.
DEMO_MODE=false
# Your dash odometer reading when logging began; added to logged distance for the
# true odometer + the 300k progress bar.
ODOMETER_BASELINE_KM=0

# --- alerts (ntfy) ---------------------------------------------------------
# Grafana pushes alerts to your phone via ntfy (free, no account). Install the
# ntfy app, then SUBSCRIBE to the topic below. Make the topic long and random —
# ntfy topics are public-by-name, so the random name IS the privacy.
#   generate one with:  echo "p300k-$(openssl rand -hex 8)"
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=p300k-CHANGE_ME_to_a_long_random_string

# --- backups ---------------------------------------------------------------
# Host directory the daily pg_dump writes to (bind-mounted into the backup
# container at /backups). On the Mac, point this at an iCloud Drive folder so the
# dumps sync OFF the laptop automatically — that is the actual off-box copy:
#   BACKUP_DIR=/Users/<you>/Library/Mobile Documents/com~apple~CloudDocs/project300k-backups
# On the real Linux server later: use a local dir (e.g. /srv/project300k-backups)
# and add an rclone push to cloud — the dump job itself is unchanged.
BACKUP_DIR=/Users/CHANGE_ME/Library/Mobile Documents/com~apple~CloudDocs/project300k-backups
# Daily run time in TZ below; retention counts. Defaults are fine for most.
TZ=UTC
BACKUP_AT=03:00
KEEP_DAILY=7
KEEP_WEEKLY=4
