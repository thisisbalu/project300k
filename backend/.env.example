# Project 300K — Backend (home server) configuration.
# Copy to .env for local dev:  cp .env.example .env
# .env is gitignored — never commit real values.
#
# This single .env serves both run modes:
#   • `make run`        — native dev; uses DATABASE_URL + API_KEY + LISTEN_ADDR
#   • `docker compose`  — uses DB_PASSWORD + API_KEY + BIND_ADDR (compose builds
#                         DATABASE_URL itself, pointing the api container at `db`)

# --- shared ----------------------------------------------------------------
# Bearer token the Pi presents on every /sync request.
# MUST match API_KEY in the Pi's /etc/obd-collector/config.env.
# Generate with: openssl rand -hex 32
API_KEY=REPLACE_ME_MATCH_THE_PI_API_KEY

# --- native dev (`make run`) -----------------------------------------------
# pgx URL against a local Postgres (Homebrew). Ignored by docker compose.
DATABASE_URL=postgres://localhost:5432/project300k_dev?sslmode=disable
LISTEN_ADDR=127.0.0.1:8080

# --- docker compose --------------------------------------------------------
# Password for the Postgres container's `app` user. Generate with: openssl rand -hex 16
DB_PASSWORD=change-me-local-dev
# Host interface the locally PUBLISHED :8080 binds to (dev convenience on the
# laptop). 127.0.0.1 keeps it off the laptop's LAN. Tailnet access to the api
# does NOT depend on this — it comes via the Tailscale sidecar.
BIND_ADDR=127.0.0.1

# --- tailscale sidecar (private mesh; the Pi reaches the laptop over this) ---
# Auth key from the Tailscale admin console → Settings → Keys (reusable,
# non-ephemeral). The laptop's Tailscale container uses it to join your tailnet.
TS_AUTHKEY=tskey-auth-REPLACE_ME
# Tailnet hostname for this laptop node (also its MagicDNS name).
TS_HOSTNAME=project300k-server
