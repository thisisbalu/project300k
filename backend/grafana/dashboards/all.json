  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "### How to read these dashboards\n🚩 **Red flags at a glance** — **Battery:** running <13.0 V (charging fault) · **Coolant:** sustained >110 °C · **Trans:** sustained >120 °C · **Misfires:** one cylinder climbing faster than the rest.\n\nThe real signal is the **trend over weeks** — _“used to be X, now drifting to Y.”_ Expand each section below for detail. Set the **Odometer baseline (km)** at top for the true 300k gauge."
      },
      "transparent": false
    },
    {
      "id": 1,
      "type": "row",
      "title": "Distance & Trips",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Distance toward 300,000 km",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT (${baseline_km} + total_distance_km) AS odometer_km FROM lifetime_distance",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "km",
          "min": 0,
          "max": 300000,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 250000
              },
              {
                "color": "red",
                "value": 290000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
