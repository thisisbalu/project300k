{
  "uid": "p300k-overview",
  "title": "Project 300K — Overview",
  "tags": [
    "project300k"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "baseline_km",
        "type": "textbox",
        "label": "Odometer baseline (km)",
        "description": "The car's odometer reading when logging began. Added to the logged distance for the true odometer.",
        "query": "0",
        "current": {
          "text": "0",
          "value": "0"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "### 📍 Distance & Trips\nProgress toward **300,000 km**. Set **Odometer baseline (km)** (top of page) to the car's dash reading on day one — the gauge then shows true odometer. No red flags here: this is your mileage log."
      },
      "transparent": false
    },
    {
      "id": 1,
      "type": "gauge",
      "title": "Distance toward 300,000 km",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT (${baseline_km} + total_distance_km) AS odometer_km FROM lifetime_distance",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "km",
          "min": 0,
          "max": 300000,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 250000
              },
              {
                "color": "red",
                "value": 290000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Logged since monitoring began",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT total_distance_km FROM lifetime_distance",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "km",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Trips logged",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT trip_count FROM lifetime_distance",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Distance per trip",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT start_time AS time, distance_km FROM trip_summary WHERE $__timeFilter(start_time) ORDER BY start_time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "km",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent trips",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "postgres",
        "uid": "project300k"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "project300k"
          },
          "rawSql": "SELECT start_time, end_time, ROUND(distance_km::numeric, 2) AS distance_km, duration_s, ROUND(avg_moving_speed_kmh::numeric, 1) AS avg_moving_kmh, max_speed_kmh FROM trip_summary WHERE $__timeFilter(start_time) ORDER BY start_time DESC LIMIT 100",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
